# --- C++ Executables and Objects ---
*.exe
*.out
*.app
*.o
*.obj

# --- Visual Studio Code Settings ---
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
# We keep tasks and launch so others can see your build/debug setup
# but we ignore the internal state
.vscode/ipch/
.vscode/browse.vc.db
.vscode/project.xcworkspace

# --- MSYS2 / Compiler Temp Files ---
*.gch
*.pdb
*.ilk
*.suo

# --- OS Generated Files ---
Thumbs.db
Desktop.ini
.DS_Store

# --- Build Directories ---
build/
bin/
debug/
release/
